# ==============================================================================
# SAMS QR Project - Environment Variables Configuration
# ==============================================================================
#
# This file serves as a reference for the environment variables required in this project.
# Do NOT input your actual production keys or secrets in this file.
#
# To configure the project:
# 1. Copy the variables from the sections below.
# 2. Paste them into their respective locations:
#    - Backend: Create a `.env` file inside the `backend/` folder.
#    - Frontend: Create a `.env` file inside the `frontend/` folder.
#
# ==============================================================================
# 1. BACKEND CONFIGURATION
# Location: backend/.env
# ==============================================================================

# The port on which the Express server runs (defaults to 5000)
PORT=5000

# MongoDB Connection String (Atlas URI or local mongodb:// URL)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# JWT Secret Key used for signing/verifying authentication tokens
JWT_SECRET=your_super_secret_jwt_key_here

# CORS allowed origins (comma-separated list of URLs allowed to request the API)
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-frontend.vercel.app


# ==============================================================================
# 2. FRONTEND CONFIGURATION
# Location: frontend/.env
# ==============================================================================

# API Base URL that the frontend client connects to.
# For production, point it to your deployed API:
VITE_API_URL=https://your-production-backend.vercel.app/api

# For local development, uncomment and use:
# VITE_API_URL=http://localhost:5000/api
